# Supabase Configuration
# Get these from https://app.supabase.com/projects/[your-project]/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Qdrant Cloud Configuration
# Your cluster endpoint (without port for Cloud)
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
# Replace with your actual API key from Qdrant Cloud dashboard  
QDRANT_APIKEY=your-qdrant-api-key

# Qdrant Edge Function Configuration
QDRANT_ENDPOINT=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=documents_pdf_texts

# Application Configuration
VITE_APP_VERSION=1.0.0
NODE_ENV=development

# Optional: Error Tracking (Sentry)
VITE_SENTRY_DSN=

# Optional: Analytics (Google Analytics)  
VITE_GA_TRACKING_ID=

# Optional: API Configuration
VITE_API_RATE_LIMIT=60
VITE_MAX_AUDIO_SIZE_MB=50
VITE_MAX_TRANSCRIPT_LENGTH=10000

# Development Configuration
VITE_DEBUG_MODE=false
VITE_MOCK_API=false